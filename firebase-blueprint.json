{
  "entities": {
    "Appointment": {
      "title": "Appointment",
      "description": "A scheduled medical appointment",
      "type": "object",
      "properties": {
        "patientName": { "type": "string", "description": "Name of the patient" },
        "patientPhone": { "type": "string", "description": "Phone number of the patient" },
        "date": { "type": "string", "format": "date", "description": "Date of the appointment (YYYY-MM-DD)" },
        "time": { "type": "string", "description": "Time of the appointment (HH:MM)" },
        "reason": { "type": "string", "description": "Reason for the visit" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"], "description": "Status of the appointment" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the appointment was created" },
        "transcript": { "type": "string", "description": "Full transcript of the call" }
      },
      "required": ["patientName", "patientPhone", "date", "time", "status"]
    },
    "ClinicInfo": {
      "title": "Clinic Info",
      "description": "General information about the clinic",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "hours": { "type": "string" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Collection of all appointments"
    },
    "/clinic_info/{infoId}": {
      "schema": "ClinicInfo",
      "description": "Clinic configuration and details"
    }
  }
}
